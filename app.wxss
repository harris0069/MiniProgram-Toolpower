/**app.wxss**/
page {
  --primary-color: #1677FF;      /* 微信蓝 */
  --orange-color: #FF7D00;       /* 橙色，用于节气/重点标记 */
  --red-color: #F53F3F;          /* 红色，用于节假日/今日日期 */
  --warn-color: #F53F3F;         /* 警示色 */
  --text-color: #333333;         /* 主文本色 */
  --sub-text-color: #666666;     /* 次要文本色 */
  --bg-color: #F5F5F5;           /* 背景色 */
  --border-color: #f0f0f0;       /* 边框颜色 */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 20rpx;
  --radius-xxl: 24rpx;
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.06);
  --shadow-lg: 0 8rpx 32rpx rgba(0,0,0,0.12);

  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Heiti SC", sans-serif;
  color: var(--text-color);
  box-sizing: border-box;
}

/* 全局容器样式，适配底部安全区域 */
.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(env(safe-area-inset-bottom));
}

/* 通用按钮样式 */
.btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 8px;
  font-size: 16px;
  text-align: center;
  transition: opacity 0.2s;
}
.btn:active {
  opacity: 0.8;
}

.btn-primary {
  background-color: var(--primary-color);
  color: #fff;
}

.btn-default {
  background-color: #fff;
  color: var(--text-color);
  border: 1rpx solid var(--border-color);
}

/* 通用卡片样式 */
.card-global {
  background: #fff;
  border-radius: 8px;
  margin: 20rpx 30rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

/* 解决iPhoneX等机型底部安全区域遮挡tabBar的问题 */
.tab-bar-safe-area {
  padding-bottom: calc(env(safe-area-inset-bottom));
}

/* 底部安全区域 */
.safe-area-bottom {
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
}
