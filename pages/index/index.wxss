/* 页面容器 - 奶白色背景 */
.container {
  background-color: #FFF9F0;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 状态栏占位 */
.status-bar {
  width: 100%;
  background-color: #FFF9F0;
}

/* 标题区域 */
.header {
  padding: 24rpx 32rpx 0;
  margin-bottom: 32rpx;
  animation: fadeInDown 0.6s ease-out;
}

.title-wrapper {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.main-title {
  font-size: 56rpx;
  font-weight: 800;
  color: #5B3A8C;
  letter-spacing: 2rpx;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

.star-emoji {
  font-size: 48rpx;
  margin-left: 12rpx;
  animation: twinkle 2s ease-in-out infinite;
}

.subtitle {
  font-size: 28rpx;
  color: #FFB347;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* 常用工具专区 */
.favorite-section {
  background: #E6F7FF;
  margin: 0 32rpx 24rpx;
  padding: 24rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(91, 58, 140, 0.08);
  animation: fadeInUp 0.5s ease-out;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.header-left {
  display: flex;
  align-items: center;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.header-right .tip-text {
  font-size: 22rpx;
  color: #999;
  font-weight: normal;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #5B3A8C;
  letter-spacing: 0.5rpx;
}

.manage-btn {
  padding: 8rpx 24rpx;
  background: rgba(91, 58, 140, 0.1);
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.manage-btn:active {
  background: rgba(91, 58, 140, 0.2);
  transform: scale(0.95);
}

.manage-text {
  font-size: 24rpx;
  color: #5B3A8C;
  font-weight: 600;
}

.favorite-scroll {
  width: 100%;
  white-space: nowrap;
  overflow: visible;
}

.favorite-tools {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  padding: 8rpx 0;
}

.favorite-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  background-color: #FFFFFF;
  padding: 16rpx 12rpx;
  border-radius: 24rpx;
  height: 80rpx;
  box-shadow: 0 4rpx 12rpx rgba(91, 58, 140, 0.08);
  transition: all 0.3s ease;
  position: relative;
  gap: 12rpx;
  margin: 12rpx 0;
}

.favorite-item:active {
  transform: scale(0.95);
}

.favorite-item.managing {
  animation: shake 0.5s ease-in-out infinite;
}

.delete-badge {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 44rpx;
  height: 44rpx;
  background: #FF6B6B;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.4);
  line-height: 1;
}

/* 常用工具的小图标 */
.icon-wrapper-small {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
}

.tool-emoji-small {
  font-size: 32rpx;
  line-height: 1;
}

.tool-name-inline {
  font-size: 24rpx;
  color: #3D2B1F;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #E0E0E0 20%, #E0E0E0 80%, transparent);
  margin: 0 32rpx 32rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

/* 全部工具区域 */
.all-tools-section {
  padding: 0 32rpx 32rpx;
}

.all-tools-section .section-header {
  margin-bottom: 20rpx;
}

.all-tools-section .tip-text {
  font-size: 22rpx;
  color: #999;
  font-weight: normal;
}

/* 工具网格 */
.tool-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  padding: 0 32rpx 32rpx;
}

/* 工具卡片 */
.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #FFFFFF;
  padding: 32rpx 16rpx;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(91, 58, 140, 0.08), 
              0 2rpx 8rpx rgba(91, 58, 140, 0.04);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  animation: fadeInUp 0.5s ease-out backwards;
  position: relative;
  overflow: visible;
}

.tool-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.8) 0%, rgba(255, 255, 255, 0) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
  border-radius: 40rpx;
}

.tool-item:active {
  transform: scale(0.95) translateY(4rpx);
  box-shadow: 0 4rpx 12rpx rgba(91, 58, 140, 0.12);
}

.tool-item:active::before {
  opacity: 1;
}

/* 图标容器 - 圆形彩色背景 */
.icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tool-item:active .icon-wrapper {
  transform: scale(0.9);
}

.tool-emoji {
  font-size: 48rpx;
  line-height: 1;
}

/* 工具名称 */
.tool-name {
  font-size: 26rpx;
  color: #3D2B1F;
  font-weight: 600;
  text-align: center;
  letter-spacing: 0.5rpx;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
}

/* 动画效果 */
@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes twinkle {
  0%, 100% {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
  50% {
    transform: scale(1.2) rotate(15deg);
    opacity: 0.8;
  }
}

@keyframes starPulse {
  0%, 100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.2);
    opacity: 0.8;
  }
}

@keyframes shake {
  0%, 100% {
    transform: translateX(0) rotate(0deg);
  }
  25% {
    transform: translateX(-2rpx) rotate(-1deg);
  }
  75% {
    transform: translateX(2rpx) rotate(1deg);
  }
}

/* 昵称输入遮罩 */
.nickname-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 9999; background: rgba(0,0,0,.45);
  display: flex; align-items: center; justify-content: center;
}
.nickname-box {
  background: #fff; border-radius: 24rpx; padding: 48rpx 40rpx 32rpx;
  width: 85%; max-width: 400px; text-align: center;
}
.nickname-icon { font-size: 64rpx; display: block; margin-bottom: 16rpx; }
.nickname-title { font-size: 36rpx; font-weight: 600; color: #1a1a1a; display: block; margin-bottom: 8rpx; }
.nickname-desc { font-size: 26rpx; color: #999; display: block; margin-bottom: 32rpx; }
.nickname-input {
  width: 100%; height: 88rpx; background: #f5f5f7; border-radius: 16rpx;
  padding: 0 24rpx; font-size: 30rpx; color: #1a1a1a; box-sizing: border-box;
  text-align: center;
}
.nickname-actions { margin-top: 24rpx; }
.nickname-btn {
  width: 100%; height: 88rpx; border-radius: 16rpx; font-size: 30rpx;
  display: flex; align-items: center; justify-content: center; border: none;
}
.nickname-btn.skip { background: #f5f5f7; color: #999; }
.nickname-btn.skip:active { opacity: .7; }
.nickname-btn::after { border: none; }