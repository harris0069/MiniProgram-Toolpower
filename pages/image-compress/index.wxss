page {
  background: #f5f5f5;
  min-height: 100vh;
  padding-top: env(safe-area-inset-top);
}

.container {
  padding: 20rpx;
  padding-bottom: 100rpx;
}

/* 顶部 */
.header {
  text-align: center;
  padding: 20rpx 0;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
}

/* 选择图片区域 */
.select-area {
  margin-top: 60rpx;
}

.select-btn {
  background: #fff;
  border: 3rpx dashed #d9d9d9;
  border-radius: 16rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  transition: all 0.3s;
}

.select-btn:active {
  background: #f9f9f9;
  border-color: #07c160;
}

.select-btn .icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.select-btn .text {
  display: block;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.select-btn .hint {
  display: block;
  font-size: 24rpx;
  color: #999;
}

/* 处理区域 */
.process-area {
  position: relative;
}

/* 预览区域 */
.preview-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.preview-image {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.image-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.image-info .size {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.image-info .dimension {
  font-size: 24rpx;
  color: #999;
}

.image-info.compressed .size {
  color: #07c160;
}

.image-info .ratio {
  font-size: 24rpx;
  color: #07c160;
  font-weight: 500;
}

/* 控制区域 */
.control-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.control-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.control-header .label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.control-header .value {
  font-size: 32rpx;
  color: #07c160;
  font-weight: bold;
}

.quality-slider {
  width: 100%;
  margin: 20rpx 0;
}

.quality-presets {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.preset {
  flex: 1;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  text-align: center;
  transition: all 0.3s;
  border: 2rpx solid transparent;
}

.preset text {
  display: block;
  font-size: 26rpx;
  color: #666;
}

.preset .desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.preset.active {
  background: rgba(7, 193, 96, 0.1);
  border-color: #07c160;
}

.preset.active text {
  color: #07c160;
  font-weight: 500;
}

/* 加载中 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-box {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 60rpx;
  text-align: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #07c160;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-box text {
  font-size: 28rpx;
  color: #333;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  border: none;
  padding: 0;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: #07c160;
  color: #fff;
}

.btn-primary[disabled] {
  background: #d9d9d9;
  color: #999;
}

.btn-secondary {
  background: #fff;
  color: #333;
  border: 2rpx solid #d9d9d9;
}

/* 底部提示 */
.footer-tip {
  text-align: center;
  padding: 40rpx 20rpx;
}

.footer-tip text {
  font-size: 24rpx;
  color: #999;
}

/* Canvas 隐藏 */
.compress-canvas {
  position: fixed;
  top: -9999rpx;
  left: -9999rpx;
  width: 1rpx;
  height: 1rpx;
}
