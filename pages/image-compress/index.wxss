/**index.wxss**/
page {
  background-color: var(--bg-color);
  padding-bottom: 120rpx; /* Space for footer */
}

.container {
  padding: 30rpx;
}

/* 顶部添加区域 */
.action-area {
  margin-bottom: 30rpx;
}

.add-btn {
  background: #fff;
  border: 2rpx dashed #d9d9d9;
  border-radius: var(--radius-lg);
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--text-sub);
  font-size: 28rpx;
  transition: all 0.2s;
}

.add-btn:active {
  background: #fafafa;
  border-color: var(--secondary-color);
  color: var(--secondary-color);
}

.icon-plus {
  font-size: 60rpx;
  font-weight: 300;
  margin-bottom: 10rpx;
  color: #ccc;
}

.tips {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-top: 16rpx;
}

/* 图片列表 */
.image-list {
  max-height: 60vh;
  margin-bottom: 30rpx;
}

.image-item {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  box-shadow: var(--shadow-sm);
}

.preview-box {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  position: relative;
  background: #f0f0f0;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.thumb {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 0;
  right: 0;
  background: rgba(0,0,0,0.5);
  color: #fff;
  width: 40rpx;
  height: 40rpx;
  text-align: center;
  line-height: 40rpx;
  border-bottom-left-radius: 8rpx;
  font-size: 28rpx;
}

.rotate-btn {
  position: absolute;
  bottom: 0;
  right: 0;
  background: rgba(255,255,255,0.9);
  color: #333;
  width: 40rpx;
  height: 40rpx;
  text-align: center;
  line-height: 40rpx;
  border-top-left-radius: 8rpx;
  font-size: 24rpx;
}

.info-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.info-row {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: var(--text-sub);
  margin-bottom: 8rpx;
}

.info-row.highlight {
  color: var(--text-main);
  font-weight: 500;
}

.value.green {
  color: var(--primary-color);
  font-weight: bold;
}

.status-badge {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: #f0f0f0;
  color: #666;
  border-radius: 20rpx;
  align-self: flex-start;
  margin-top: 8rpx;
}

.status-badge.error {
  background: #fee;
  color: #f00;
}

/* 设置面板 */
.settings-panel {
  background: var(--card-bg);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  padding: 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom)); /* Adjust for button bar */
}

.setting-item {
  margin-bottom: 30rpx;
}

.setting-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-main);
  margin-bottom: 20rpx;
  font-weight: 500;
}

.setting-slider {
  margin: 0 10rpx;
}

.quick-tags, .radio-group {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.tag, .radio-tag {
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  border-radius: 30rpx;
  background: #f5f5f5;
  color: var(--text-sub);
  border: 1px solid transparent;
  transition: all 0.2s;
}

.tag.active, .radio-tag.active {
  background: rgba(26, 95, 74, 0.1);
  color: var(--primary-color);
  border-color: var(--primary-color);
  font-weight: 500;
}

/* 底部按钮 */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
  z-index: 200;
}

.btn-group {
  display: flex;
  gap: 20rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: var(--radius-md);
  font-size: 30rpx;
  border: none;
}

.btn::after { border: none; }

.btn.primary {
  background: var(--primary-color);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(26, 95, 74, 0.3);
}

.btn.secondary {
  background: #f5f5f5;
  color: #666;
}

.btn[disabled] {
  opacity: 0.6;
  background: #eee !important;
  color: #999 !important;
  box-shadow: none !important;
}
