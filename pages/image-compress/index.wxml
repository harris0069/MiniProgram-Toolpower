<navigation-bar title="图片压缩" back="{{true}}" color="black" background="#FFF"></navigation-bar>

<view class="container">
  <!-- 顶部说明 -->
  <view class="header">
    <text class="subtitle">单张压缩 · 清晰优先 · 本地处理</text>
  </view>

  <!-- 选择图片按钮 -->
  <view class="select-area" wx:if="{{!originalImage}}">
    <view class="select-btn" bindtap="selectImage">
      <text class="icon">📷</text>
      <text class="text">选择图片</text>
      <text class="hint">支持相册选择或拍照</text>
    </view>
  </view>

  <!-- 图片处理区域 -->
  <view class="process-area" wx:if="{{originalImage}}">
    <!-- 原图预览 -->
    <view class="preview-section">
      <view class="section-title">原图</view>
      <image class="preview-image" src="{{originalImage}}" mode="aspectFit" bindtap="previewOriginal"></image>
      <view class="image-info">
        <text class="size">{{originalSize}}</text>
        <text class="dimension">{{originalWidth}} × {{originalHeight}}</text>
      </view>
    </view>

    <!-- 压缩控制 -->
    <view class="control-section">
      <view class="control-header">
        <text class="label">压缩质量</text>
        <text class="value">{{quality}}%</text>
      </view>
      <slider 
        class="quality-slider" 
        value="{{quality}}" 
        min="10" 
        max="100" 
        step="5" 
        bindchange="onQualityChange"
        bindchanging="onQualityChanging"
        activeColor="#07c160"
        backgroundColor="#e9e9e9"
        block-size="24"
      />
      <view class="quality-presets">
        <view class="preset {{quality === 60 ? 'active' : ''}}" bindtap="setQuality" data-value="60">
          <text>高压缩</text>
          <text class="desc">体积小</text>
        </view>
        <view class="preset {{quality === 80 ? 'active' : ''}}" bindtap="setQuality" data-value="80">
          <text>推荐</text>
          <text class="desc">平衡</text>
        </view>
        <view class="preset {{quality === 95 ? 'active' : ''}}" bindtap="setQuality" data-value="95">
          <text>高质量</text>
          <text class="desc">清晰</text>
        </view>
      </view>
    </view>

    <!-- 压缩后预览 -->
    <view class="preview-section" wx:if="{{compressedImage}}">
      <view class="section-title">压缩后</view>
      <image class="preview-image" src="{{compressedImage}}" mode="aspectFit" bindtap="previewCompressed"></image>
      <view class="image-info compressed">
        <text class="size">{{compressedSize}}</text>
        <text class="ratio">缩小 {{compressionRatio}}%</text>
      </view>
    </view>

    <!-- 加载中 -->
    <view class="loading-overlay" wx:if="{{isCompressing}}">
      <view class="loading-box">
        <view class="loading-spinner"></view>
        <text>压缩中...</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons">
      <button class="btn btn-secondary" bindtap="reselect">
        <text>重新选择</text>
      </button>
      <button class="btn btn-primary" bindtap="saveImage" disabled="{{!compressedImage || isCompressing}}">
        <text>💾 保存到相册</text>
      </button>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tip">
    <text>* 所有压缩均在本地完成，不会上传您的图片，请放心使用</text>
  </view>

  <!-- Canvas 用于压缩 -->
  <canvas type="2d" id="compressCanvas" class="compress-canvas"></canvas>
</view>
