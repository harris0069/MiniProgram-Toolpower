page {
  background: #f5f5f5;
  height: 100%;
}

.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

/* 顶部 */
.header {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.help-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
}

/* 形状选择 */
.shape-selector {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 0;
  margin-bottom: 20rpx;
}

.shape-scroll {
  white-space: nowrap;
}

.shape-list {
  display: inline-flex;
  padding: 0 20rpx;
  gap: 24rpx;
}

.shape-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.shape-item.active {
  background: rgba(7, 193, 96, 0.1);
}

.shape-item text {
  font-size: 24rpx;
  color: #666;
  white-space: nowrap;
}

.shape-item.active text {
  color: #07c160;
  font-weight: 500;
}

.shape-icon {
  width: 60rpx;
  height: 60rpx;
  border: 3rpx solid #d9d9d9;
  transition: all 0.3s;
}

.shape-item.active .shape-icon {
  border-color: #07c160;
}

.circle-icon {
  border-radius: 50%;
}

.oval-icon {
  border-radius: 50%;
  width: 60rpx;
  height: 45rpx;
}

.square-icon {
  border-radius: 8rpx;
}

.rect-icon {
  border-radius: 8rpx;
  width: 80rpx;
  height: 50rpx;
}

.oval-h-icon {
  border-radius: 50%;
  width: 80rpx;
  height: 45rpx;
}

/* 预览区域 */
.preview-area {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.preview-box {
  width: 600rpx;
  height: 600rpx;
  background-image: 
    linear-gradient(45deg, #f0f0f0 25%, transparent 25%),
    linear-gradient(-45deg, #f0f0f0 25%, transparent 25%),
    linear-gradient(45deg, transparent 75%, #f0f0f0 75%),
    linear-gradient(-45deg, transparent 75%, #f0f0f0 75%);
  background-size: 20rpx 20rpx;
  background-position: 0 0, 0 10rpx, 10rpx -10rpx, -10rpx 0rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}

.seal-canvas {
  width: 600rpx;
  height: 600rpx;
  position: relative;
}

/* 参数区域 */
.params-area {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.param-section {
  margin-bottom: 32rpx;
}

.param-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

/* 输入框 */
.input-group {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 16rpx;
}

.input-group .label {
  font-size: 26rpx;
  color: #666;
  width: 120rpx;
  flex-shrink: 0;
}

.text-input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.char-count {
  font-size: 22rpx;
  color: #999;
  width: 80rpx;
  text-align: right;
  flex-shrink: 0;
}

/* 颜色列表 */
.color-list {
  display: flex;
  gap: 24rpx;
}

.color-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.color-item.active {
  background: rgba(7, 193, 96, 0.1);
}

.color-block {
  width: 60rpx;
  height: 60rpx;
  border-radius: 8rpx;
  border: 2rpx solid #e0e0e0;
}

.color-item text {
  font-size: 24rpx;
  color: #666;
}

.color-item.active text {
  color: #07c160;
  font-weight: 500;
}

/* 滑块 */
.size-slider {
  width: 100%;
  margin-top: 10rpx;
}

/* 操作按钮 */
.action-area {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  border: none;
  padding: 0;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: #07c160;
  color: #fff;
}

.btn-secondary {
  background: #fff;
  color: #333;
  border: 2rpx solid #d9d9d9;
}

/* 免责声明 */
.disclaimer {
  text-align: center;
  padding: 20rpx;
}

.disclaimer text {
  font-size: 22rpx;
  color: #999;
}

/* 帮助弹窗 */
.help-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.help-content {
  width: 600rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
}

.help-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  text-align: center;
}

.help-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 32rpx;
}

.help-text .warning {
  color: #ff6b6b;
  font-weight: 500;
}

.help-close {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}

.help-close::after {
  border: none;
}
