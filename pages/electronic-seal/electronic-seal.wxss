/* pages/electronic-seal/electronic-seal.wxss */
/* 全局重置 */
page {
  height: 100vh;
  background-color: var(--card-bg);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Heiti SC", "Segoe UI", Roboto, sans-serif;
}

/* 顶级Flex容器 */
.page-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* ================= Level 1: 预览区 (Z: 10) ================= */
.preview-layer {
  flex-shrink: 0;
  height: 45vh; /* 占据屏幕45% */
  background-color: var(--bg-color); /* 实色背景，禁止透明 */
  position: relative;
  z-index: 10;
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: center;
  /* 物理隔离阴影 */
  box-shadow: inset 0 -1px 0 rgba(0,0,0,0.05);
}

.canvas-wrapper {
  width: 260px;
  height: 260px;
  position: relative;
  background-color: #FFFFFF;
  box-shadow: var(--shadow-md);
  /* 棋盘格背景 */
  background-image: linear-gradient(45deg, #f0f0f0 25%, transparent 25%), 
                    linear-gradient(-45deg, #f0f0f0 25%, transparent 25%), 
                    linear-gradient(45deg, transparent 75%, #f0f0f0 75%), 
                    linear-gradient(-45deg, transparent 75%, #f0f0f0 75%);
  background-size: 20px 20px;
  border-radius: 4rpx;
  will-change: transform; /* 优化渲染性能 */
}

.seal-canvas {
  width: 100%;
  height: 100%;
}

.watermark {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) rotate(-45deg);
  width: 120%;
  text-align: center;
  font-size: 14px;
  color: rgba(0,0,0,0.06);
  pointer-events: none;
}

.preview-tools {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  display: flex;
  gap: 16rpx;
}

.mini-tool-btn {
  width: 64rpx;
  height: 64rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-sm);
  color: #666;
}

.icon-reset {
  font-size: 18px;
  font-weight: bold;
}

/* ================= Level 2: 控制面板 (Z: 20) ================= */
.control-layer {
  flex: 1; /* 占据剩余空间 */
  background-color: var(--card-bg); /* 实色背景 */
  position: relative;
  z-index: 20;
  /* 顶部圆角营造层叠感 */
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  margin-top: -32rpx; /* 负边距实现层叠 */
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.04);
  display: flex;
  flex-direction: column;
}

/* 顶部把手指示条 */
.drag-handle {
  width: 100%;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.handle-bar {
  width: 60rpx;
  height: 8rpx;
  background-color: #E0E0E0;
  border-radius: 4rpx;
}

/* Tab导航栏 */
.tab-bar {
  display: flex;
  padding: 0 40rpx;
  border-bottom: 1px solid var(--border-color);
  flex-shrink: 0;
}

.tab-item {
  position: relative;
  margin-right: 60rpx;
  padding: 24rpx 0;
  font-size: 15px;
  color: var(--text-sub);
  transition: all 0.3s;
}

.tab-item.active {
  color: var(--text-main);
  font-weight: 600;
  font-size: 16px;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background-color: var(--secondary-color);
  border-radius: 3rpx;
}

/* 滚动内容区 */
.scroll-content {
  flex: 1;
  padding: 30rpx 40rpx;
  box-sizing: border-box;
}

.spacer {
  height: 180rpx; /* 底部垫高，防止按钮遮挡 */
}

/* 样式组通用 */
.style-group {
  margin-bottom: 40rpx;
}

.group-title {
  font-size: 13px;
  color: var(--text-sub);
  margin-bottom: 20rpx;
  font-weight: 500;
}

/* 形状选择网格 */
.shape-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 20rpx;
}

.shape-item {
  aspect-ratio: 1;
  border-radius: 12rpx;
  background-color: var(--bg-color);
  border: 1px solid transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.shape-item.active {
  border-color: var(--secondary-color);
  background-color: rgba(212, 185, 140, 0.1);
}

.shape-icon {
  width: 40rpx;
  height: 40rpx;
  border: 2px solid #999;
  margin-bottom: 8rpx;
}

.shape-item.active .shape-icon {
  border-color: var(--secondary-color);
}

.shape-name {
  font-size: 10px;
  color: #666;
}

/* 圆形图标 */
.shape-icon.circle { border-radius: 50%; }
.shape-icon.oval { border-radius: 50%; transform: scaleX(1.2); }
.shape-icon.square { border-radius: 4rpx; }
.shape-icon.rhombus { transform: rotate(45deg) scale(0.7); border-radius: 4rpx; }
.shape-icon.shield { border-radius: 0 0 50% 50%; border-top: none; height: 36rpx; width: 36rpx; position: relative; }
.shape-icon.shield::before { content:''; position: absolute; top:-2px; left:-2px; width: 40rpx; height: 10rpx; border: 2px solid #999; border-bottom: none; }

/* 输入框 */
.input-row {
  background-color: var(--bg-color);
  border-radius: 12rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  border: 1px solid transparent;
  transition: border-color 0.2s;
}

.input-row:focus-within {
  border-color: var(--secondary-color);
}

.input-row input {
  flex: 1;
  font-size: 15px;
  color: var(--text-main);
}

.input-counter {
  font-size: 12px;
  color: #ccc;
  margin-left: 10rpx;
}

/* 颜色选择 */
.color-scroll {
  white-space: nowrap;
  display: flex;
  padding-bottom: 10rpx;
}

.color-item {
  display: inline-block;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  position: relative;
  border: 2px solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.color-item.active {
  transform: scale(1.1);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
}

.color-check {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #fff;
  font-size: 12px;
}

/* 滑动条行 */
.slider-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.slider-label {
  width: 120rpx;
  font-size: 13px;
  color: var(--text-main);
}

.slider-comp {
  flex: 1;
}

.slider-val {
  width: 60rpx;
  text-align: right;
  font-size: 12px;
  color: var(--text-sub);
}

/* 历史记录 */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  display: flex;
  align-items: center;
  background-color: var(--bg-color);
  padding: 20rpx;
  border-radius: 12rpx;
}

.h-preview {
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 8rpx;
  margin-right: 20rpx;
  overflow: hidden;
}

.h-info {
  flex: 1;
}

.h-title {
  font-size: 14px;
  color: var(--text-main);
  font-weight: 500;
  margin-bottom: 4rpx;
}

.h-date {
  font-size: 11px;
  color: #999;
}

.h-btn {
  padding: 8rpx 20rpx;
  background-color: #fff;
  border: 1px solid var(--border-color);
  border-radius: 30rpx;
  font-size: 12px;
  color: var(--text-main);
}

/* 底部操作栏 */
.action-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  border-top: 1px solid rgba(0,0,0,0.05);
  display: flex;
  gap: 20rpx;
  z-index: 30;
}

.btn-secondary, .btn-primary {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 500;
  transition: opacity 0.2s;
}

.btn-secondary {
  background-color: #F5F5F5;
  color: #333;
}

.btn-primary {
  background-color: var(--primary-color); /* 深绿主题色 */
  color: #FFFFFF;
  box-shadow: 0 8rpx 20rpx rgba(26, 95, 74, 0.25);
}

.btn-primary:active {
  opacity: 0.9;
}
