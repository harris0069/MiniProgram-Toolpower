page {
  background-color: #F8F7F4;
  height: 100vh;
  display: flex;
  flex-direction: column;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Heiti SC", sans-serif;
}

.container {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
}

.guide-tip {
  text-align: center;
  font-size: 12px;
  color: #999;
  margin-bottom: 24rpx;
}

/* 预览卡片 */
.preview-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02);
  /* 网格背景显示透明 */
  background-image: linear-gradient(45deg, #f5f5f5 25%, transparent 25%), 
                    linear-gradient(-45deg, #f5f5f5 25%, transparent 25%), 
                    linear-gradient(45deg, transparent 75%, #f5f5f5 75%), 
                    linear-gradient(-45deg, transparent 75%, #f5f5f5 75%);
  background-size: 20px 20px;
  background-position: 0 0, 0 10px, 10px -10px, -10px 0px;
  background-color: #fff; /* 覆盖部分网格 */
}

.canvas-wrapper {
  width: 240px;
  height: 240px;
  position: relative;
}

.seal-canvas {
  width: 100%;
  height: 100%;
}

.preview-label {
  font-size: 12px;
  color: #ccc;
  margin-top: 16rpx;
}

/* 配置卡片 */
.config-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 120rpx; /* 为底部按钮留空 */
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02);
}

.section-title {
  font-size: 14px;
  font-weight: 600;
  color: #1C1917;
  margin-bottom: 24rpx;
  padding-left: 12rpx;
  border-left: 3px solid #D4B98C;
}

.input-group {
  margin-bottom: 24rpx;
}

.label {
  display: block;
  font-size: 13px;
  color: #666;
  margin-bottom: 12rpx;
}

.input-field {
  background: #F8F7F4;
  height: 80rpx;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 15px;
  color: #333;
  border: 1px solid #E7E5E4;
}

/* 颜色选择 */
.color-selector {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.color-item {
  flex: 1;
  background: #F8F7F4;
  padding: 16rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  color: #666;
  border: 1px solid transparent;
  transition: all 0.2s;
}

.color-item.active {
  background: #fff;
  border-color: #D4B98C;
  color: #D4B98C;
  box-shadow: 0 2rpx 8rpx rgba(212, 185, 140, 0.2);
}

.color-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

/* 形状选择 */
.shape-selector {
  display: flex;
  gap: 20rpx;
}

.shape-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: #F8F7F4;
  border-radius: 12rpx;
  font-size: 13px;
  color: #666;
  border: 1px solid transparent;
}

.shape-item.active {
  background: #fff;
  border-color: #D4B98C;
  color: #D4B98C;
  font-weight: 500;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: #fff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
  display: flex;
  gap: 24rpx;
  z-index: 100;
}

.btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 16px;
  font-weight: 500;
  margin: 0;
  padding: 0;
  flex: 1;
}

.btn::after { border: none; }

.btn.secondary {
  background: #F5F2EF;
  color: #666;
}

.btn.primary {
  background: linear-gradient(135deg, #1A5F4A 0%, #2D7A62 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(26, 95, 74, 0.3);
}

.btn.primary:active {
  transform: scale(0.98);
}