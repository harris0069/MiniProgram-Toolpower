/* 水印工具 - 页面样式 */

/* ========== 补充变量（继承 app.wxss） ========== */
page {
  --wm-bg-preview: #EEEEF0;
  --wm-text-secondary: #8E8E93;
  --wm-text-tertiary: #C7C7CC;
  --wm-border-light: #F2F2F7;
  --wm-color-error: #D96B6B;

  background: var(--bg-color);
  height: 100vh;
}

/* ========== 容器 ========== */
.container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg-color);
}

/* ========== 导航栏 ========== */
.nav-right {
  display: flex;
  align-items: center;
}

.reset-btn {
  font-size: 28rpx;
  font-weight: 400;
  color: var(--sub-text-color);
  padding: 8rpx 16rpx;
  transition: color 200ms ease-out;
}

.reset-btn:active {
  opacity: 0.7;
  transform: scale(0.98);
}

/* ========== 内容区域 ========== */
.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ========== 预览区 ========== */
.preview-section {
  width: 100%;
  flex: 0 0 42%;
  min-height: 0;
  background: var(--wm-bg-preview);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
  border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  border: 1px solid var(--border-color);
}

.watermark-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

/* 空状态覆盖层 */
.empty-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}
.empty-overlay .empty-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}
.empty-overlay .empty-text {
  font-size: 28rpx;
  color: var(--wm-text-secondary);
  opacity: 0.8;
}

/* 拖拽提示 */
.drag-hint {
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.7);
  color: #FFFFFF;
  padding: 16rpx 32rpx;
  border-radius: var(--radius-xxl);
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  animation: fadeIn 0.3s ease;
  pointer-events: none;
  box-shadow: var(--shadow-md);
}

.icon {
  display: inline-block;
  font-style: normal;
  line-height: 1;
  text-align: center;
  vertical-align: middle;
}

.icon-hand {
  font-size: 32rpx;
}

.hint-text {
  font-size: 24rpx;
  line-height: 1.4;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateX(-50%) translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
}

/* ========== Tab 栏 ========== */
.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid var(--border-color);
  flex-shrink: 0;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  position: relative;
  transition: color 200ms ease-out;
  color: var(--sub-text-color);
}

.tab-item.active {
  color: var(--primary-color);
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: var(--primary-color);
  border-radius: 2rpx;
  transition: all 200ms ease-out;
}

.icon-text,
.icon-image,
.icon-grid {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.tab-text {
  font-size: 28rpx;
  font-weight: 400;
}

/* ========== 参数卡片分组 ========== */
.param-card {
  background: #fff;
  border-radius: var(--radius-lg);
  margin-bottom: 24rpx;
  overflow: hidden;
  border: 1rpx solid var(--wm-border-light);
}

.card-header {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--primary-color);
  padding: 24rpx 28rpx 0;
  letter-spacing: 0.5px;
}

.card-body {
  padding: 20rpx 28rpx 8rpx;
}

.card-body .param-group {
  margin-bottom: 36rpx;
  padding-top: 0;
  border-top: none;
}

.card-body .param-group:last-child {
  margin-bottom: 0;
}

/* ========== 参数调节区 ========== */
.params-section {
  flex: 1;
  background: #fff;
  margin-top: 30rpx;
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  overflow-y: auto;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.04);
}

.params-content {
  padding: 32rpx 30rpx;
  /* 底部预留空间，避免被底部操作栏遮挡 */
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.param-group {
  margin-bottom: 64rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid var(--wm-border-light);
}

.param-group:first-child {
  padding-top: 0;
  border-top: none;
}

.param-group:last-child {
  margin-bottom: 0;
}

.param-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-color);
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.param-input {
  width: 100%;
  height: 88rpx;
  background: var(--bg-color);
  border: 1rpx solid var(--border-color);
  border-radius: var(--radius-lg);
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text-color);
  box-sizing: border-box;
  transition: all 200ms ease-out;
}

.param-input:focus {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 3rpx rgba(74, 144, 217, 0.1);
}

.param-slider {
  width: 100%;
}

.line-slider {
  width: 100%;
}

/* 快捷角度按钮 */
.quick-angles {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.angle-btn {
  flex: 1;
  height: 64rpx;
  background: var(--bg-color);
  border: 1rpx solid var(--border-color);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--sub-text-color);
  transition: all 200ms ease-out;
}

.angle-btn:active {
  opacity: 0.7;
  transform: scale(0.98);
}

/* 颜色选择器 */
.color-picker {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.color-item {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  position: relative;
  transition: all 200ms ease-out;
  border: 2rpx solid transparent;
}

.color-item.active {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx rgba(74, 144, 217, 0.2);
}

.color-item.active::after {
  content: '✓';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  transform: translate(-50%, -50%);
  background: rgba(0,0,0,0.25);
  border-radius: 50%;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
}

.color-item:active {
  opacity: 0.7;
  transform: scale(0.98);
}

/* 多行文字 */
.multi-lines {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.line-item {
  background: var(--bg-color);
  border: 1rpx solid var(--border-color);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  position: relative;
}

.line-header {
  margin-bottom: 16rpx;
}

.line-number {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--primary-color);
}

.line-input {
  width: 100%;
  height: 72rpx;
  background: #fff;
  border: 1rpx solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--text-color);
  margin-bottom: 20rpx;
  box-sizing: border-box;
  transition: border-color 200ms ease-out;
}

.line-input:focus {
  border-color: var(--primary-color);
}

.line-font-size {
  margin-bottom: 20rpx;
}

.line-label {
  font-size: 24rpx;
  color: var(--sub-text-color);
  display: block;
  margin-bottom: 12rpx;
}

.line-slider {
  width: 100%;
  height: 44px;
  padding: 8px 0;
}

.line-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--wm-border-light);
}

.line-remove-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: rgba(217, 107, 107, 0.08);
  border: 1rpx solid rgba(217, 107, 107, 0.2);
  border-radius: var(--radius-md);
  transition: all 200ms ease-out;
}

.line-remove-btn:active {
  opacity: 0.7;
  transform: scale(0.98);
}

.icon-delete {
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1;
}

.remove-text {
  font-size: 24rpx;
  color: var(--wm-color-error);
  font-weight: 500;
}

.add-line-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 200ms ease-out;
}

.add-line-btn::after {
  border: none;
}

.add-line-btn:active {
  opacity: 0.7;
  transform: scale(0.98);
}

/* 快捷定位 */
.quick-positions {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12rpx;
}

.position-btn {
  height: 96rpx;
  background: var(--bg-color);
  border: 1rpx solid var(--border-color);
  border-radius: var(--radius-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  transition: all 200ms ease-out;
}

.position-btn:active {
  opacity: 0.7;
  transform: scale(0.98);
}

.position-btn.active {
  border-color: var(--primary-color);
  background: rgba(74, 144, 217, 0.08);
}

.icon-arrow-tl,
.icon-arrow-tr,
.icon-arrow-bl,
.icon-arrow-br,
.icon-center {
  font-size: 32rpx;
  color: var(--primary-color);
  font-weight: 600;
}

.position-text {
  font-size: 20rpx;
  color: var(--sub-text-color);
}

/* 水印空状态 */
.watermark-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}
.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}
.empty-desc {
  font-size: 26rpx;
  color: var(--sub-text-color);
}

/* 选择水印图按钮 */
.choose-watermark-btn {
  width: 100%;
  height: 88rpx;
  background: var(--primary-color);
  color: #FFFFFF;
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 200ms ease-out;
}

.choose-watermark-btn::after {
  border: none;
}

.choose-watermark-btn:active {
  opacity: 0.7;
  transform: scale(0.98);
}

/* 模式切换 */
.mode-switch {
  display: flex;
  gap: 16rpx;
}

.mode-btn {
  flex: 1;
  height: 80rpx;
  background: var(--bg-color);
  border: 1rpx solid var(--border-color);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--sub-text-color);
  transition: all 200ms ease-out;
}

.mode-btn.active {
  background: var(--primary-color);
  border-color: var(--primary-color);
  color: #FFFFFF;
}

.mode-btn:active {
  opacity: 0.7;
  transform: scale(0.98);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 140rpx;
  background: #fff;
  border-top: 1rpx solid var(--border-color);
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  z-index: 100;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.04);
}

.bottom-btn {
  height: 96rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 200ms ease-out;
}

.bottom-btn.secondary {
  flex: 0 0 38%;
  background: transparent;
  border: 2rpx solid var(--border-color);
  color: var(--sub-text-color);
}

.bottom-btn.secondary:active {
  opacity: 0.7;
  transform: scale(0.98);
}

.bottom-btn.primary {
  flex: 0 0 60%;
  background: var(--primary-color);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.4);
  font-weight: 600;
}

.bottom-btn.primary:active {
  opacity: 0.7;
  transform: scale(0.98);
}

.bottom-btn.disabled {
  opacity: 0.4;
  pointer-events: none;
}
.bottom-btn.secondary.disabled {
  border-color: var(--wm-text-tertiary);
  color: var(--wm-text-tertiary);
}

.icon-folder {
  font-size: 40rpx;
  font-weight: 600;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 500;
}
