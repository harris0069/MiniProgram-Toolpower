/* 纪念日工具 - 新建页面 */
.container {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(135deg, #FFE5F0 0%, #FFF0F7 100%);
}

.content {
  width: 100%;
  min-height: calc(100vh - 140rpx);
  padding: 0 30rpx 140rpx 30rpx;
  box-sizing: border-box;
}

/* 表单 */
.form {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.form-item {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 182, 217, 0.1);
}

.form-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.label-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.required {
  font-size: 28rpx;
  color: #FF6B9D;
}

/* 输入框 */
.input-wrapper {
  position: relative;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 100rpx 0 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #BFBFBF;
}

.char-count {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 24rpx;
  color: #999;
}

/* 日期选择器 */
.date-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  padding: 0 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
}

.date-text {
  font-size: 30rpx;
  color: #333;
}

.picker-icon {
  font-size: 48rpx;
  color: #BFBFBF;
  font-weight: 300;
  line-height: 1;
  transform: rotate(90deg);
}

/* 保存按钮 */
.button-wrapper {
  position: fixed;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
}

.save-button {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  transition: all 0.3s ease;
}

.save-button.active {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FB3 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 157, 0.3);
}

.save-button.active::after {
  border: none;
}

.save-button.disabled {
  background: #E0E0E0;
  color: #999;
}

.save-button.disabled::after {
  border: none;
}

.save-button.active:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 157, 0.4);
}


/* 历法类型切换 */
.calendar-switch {
  display: flex;
  gap: 16rpx;
}

.switch-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F8F8F8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s ease;
}

.switch-btn.active {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FB3 100%);
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 157, 0.3);
}


/* 重复开关 */
.repeat-wrapper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
}

.repeat-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.repeat-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.repeat-hint {
  font-size: 24rpx;
  color: #999;
}

.repeat-switch {
  transform: scale(0.9);
}

/* 备注输入框 */
.textarea-wrapper {
  position: relative;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 24rpx;
  padding-bottom: 60rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  line-height: 1.6;
}

.form-textarea::placeholder {
  color: #BFBFBF;
}

.textarea-wrapper .char-count {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  font-size: 24rpx;
  color: #999;
}


/* Emoji选择器 */
.emoji-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  padding: 0 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.emoji-selector:active {
  background: #EFEFEF;
}

.selected-emoji {
  font-size: 48rpx;
  line-height: 1;
}

.selector-hint {
  font-size: 26rpx;
  color: #999;
}

/* Emoji选择器弹窗 */
.emoji-picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  align-items: flex-end;
}

.emoji-picker-container {
  width: 100%;
  max-height: 75vh;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.emoji-picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  padding: 0 32rpx;
  border-bottom: 2rpx solid #F0F0F0;
  flex-shrink: 0;
}

.emoji-picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.emoji-picker-close {
  font-size: 40rpx;
  color: #999;
  padding: 8rpx;
  line-height: 1;
}

.emoji-picker-body {
  flex: 1;
  padding: 24rpx 24rpx;
  overflow-y: auto;
}

/* 分类 */
.emoji-category {
  margin-bottom: 40rpx;
}

.emoji-category:last-child {
  margin-bottom: 0;
}

.category-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #F5F5F5;
}

.category-icon {
  font-size: 36rpx;
  line-height: 1;
}

.category-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
}

.category-emojis {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 12rpx;
}

.emoji-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  font-size: 40rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.emoji-item:active {
  background: #FFE5F0;
  transform: scale(0.95);
}
