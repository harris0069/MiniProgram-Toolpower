<!-- 纪念日工具 - 新建/编辑页面 V1.0.2 -->
<view class="container">
  <!-- 自定义导航栏 -->
  <navigation-bar 
    title="{{isEdit ? '编辑纪念日' : '新建纪念日'}}" 
    statusBarHeight="{{statusBarHeight}}" 
    navBarHeight="{{navBarHeight}}"
    bind:back="goBack"
  />

  <!-- 内容区域 -->
  <view class="content" style="padding-top: {{navBarHeight + 10}}px;">
    <!-- 表单 -->
    <view class="form">
      <!-- Emoji选择 -->
      <view class="form-item">
        <view class="form-label">
          <text class="label-text">表情图标</text>
        </view>
        <view class="emoji-selector" bindtap="openEmojiPicker">
          <text class="selected-emoji">{{emoji}}</text>
          <text class="selector-hint">点击选择</text>
        </view>
      </view>

      <!-- 纪念日名称 -->
      <view class="form-item">
        <view class="form-label">
          <text class="label-text">纪念日名称</text>
          <text class="required">*</text>
        </view>
        <view class="input-wrapper">
          <input 
            class="form-input" 
            type="text" 
            placeholder="请输入纪念日名称"
            value="{{name}}"
            bindinput="onNameInput"
            maxlength="20"
          />
          <text class="char-count">{{nameLength}}/20</text>
        </view>
      </view>

      <!-- 历法类型切换 -->
      <view class="form-item">
        <view class="form-label">
          <text class="label-text">历法类型</text>
          <text class="required">*</text>
        </view>
        <view class="calendar-switch">
          <view 
            class="switch-btn {{calendarType === 'solar' ? 'active' : ''}}"
            bindtap="switchCalendarType"
            data-type="solar"
          >
            国历
          </view>
          <view 
            class="switch-btn {{calendarType === 'lunar' ? 'active' : ''}}"
            bindtap="switchCalendarType"
            data-type="lunar"
          >
            农历
          </view>
        </view>
      </view>

      <!-- 日期选择 -->
      <view class="form-item">
        <view class="form-label">
          <text class="label-text">日期</text>
          <text class="required">*</text>
        </view>
        <view class="date-picker" bindtap="openDatePicker">
          <text class="date-text">{{dateDisplay}}</text>
          <text class="picker-icon">›</text>
        </view>
      </view>

      <!-- 是否重复 -->
      <view class="form-item">
        <view class="form-label">
          <text class="label-text">是否重复</text>
        </view>
        <view class="repeat-wrapper">
          <view class="repeat-info">
            <text class="repeat-text">每年重复</text>
            <text class="repeat-hint" wx:if="{{repeat}}">开启后每年同一日期提醒</text>
          </view>
          <switch 
            class="repeat-switch" 
            checked="{{repeat}}" 
            bindchange="onRepeatChange"
            color="#FF6B9D"
          />
        </view>
      </view>

      <!-- 备注 -->
      <view class="form-item">
        <view class="form-label">
          <text class="label-text">备注</text>
        </view>
        <view class="textarea-wrapper">
          <textarea 
            class="form-textarea" 
            placeholder="记录纪念日相关备注（选填）"
            value="{{remark}}"
            bindinput="onRemarkInput"
            maxlength="100"
            auto-height
          />
          <text class="char-count">{{remarkLength}}/100</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="button-wrapper">
    <button 
      class="save-button {{canSubmit ? 'active' : 'disabled'}}" 
      bindtap="saveAnniversary"
    >
      {{isEdit ? '保存修改' : '保存'}}
    </button>
  </view>

  <!-- 自定义日期选择器 -->
  <date-picker 
    show="{{showDatePicker}}"
    value="{{date}}"
    minDate="1900-01-01"
    maxDate="2100-12-31"
    bind:confirm="onDateConfirm"
    bind:cancel="onDateCancel"
  />

  <!-- Emoji选择器 -->
  <view class="emoji-picker-overlay" wx:if="{{showEmojiPicker}}" bindtap="closeEmojiPicker">
    <view class="emoji-picker-container" catchtap="stopPropagation">
      <view class="emoji-picker-header">
        <text class="emoji-picker-title">选择表情</text>
        <text class="emoji-picker-close" bindtap="closeEmojiPicker">✕</text>
      </view>
      <scroll-view class="emoji-picker-body" scroll-y>
        <view class="emoji-category" wx:for="{{emojiCategories}}" wx:key="name">
          <view class="category-header">
            <text class="category-icon">{{item.icon}}</text>
            <text class="category-name">{{item.name}}</text>
          </view>
          <view class="category-emojis">
            <view 
              class="emoji-item" 
              wx:for="{{item.emojis}}" 
              wx:key="index"
              wx:for-item="emoji"
              bindtap="selectEmoji"
              data-emoji="{{emoji}}"
            >
              {{emoji}}
            </view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
