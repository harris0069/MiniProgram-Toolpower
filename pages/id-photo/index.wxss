/**index.wxss**/
page {
  background-color: var(--bg-color);
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  padding: 0;
  position: relative;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.guide-tip {
  text-align: center;
  font-size: 22rpx;
  color: var(--sub-text-color);
  padding: 12rpx 0;
  line-height: 1.4;
}

/* 预览区 */
.preview-area {
  flex: 1;
  min-height: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  background: #f0f0f0;
  margin: 12rpx 24rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  position: relative;
  box-shadow: inset 0 0 20rpx rgba(0,0,0,0.05);
}

.canvas-box {
  position: relative;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.1);
  overflow: hidden;
  background: #fff;
  transition: all 0.3s ease;
  max-width: 100%;
  max-height: 100%;
}

.photo-canvas {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

.user-photo {
  position: absolute;
  top: 0;
  left: 0;
  transform-origin: 0 0;
  z-index: 2;
}

.guide-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 3;
  pointer-events: none;
  border: 2rpx solid rgba(255,255,255,0.5);
  box-sizing: border-box;
}

.guide-line {
  position: absolute;
  left: 0;
  width: 100%;
  height: 2rpx;
  background: rgba(255,255,255,0.3);
}

.head-line { top: 20%; }
.chin-line { top: 80%; }
.guide-center {
  position: absolute;
  top: 0;
  left: 50%;
  width: 2rpx;
  height: 100%;
  background: rgba(255,255,255,0.3);
}

/* AI 抠图提示 */
.ai-tip {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  background: rgba(22, 119, 255, 0.9);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  z-index: 5;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
  animation: fadeIn 0.3s ease;
}

.tip-icon {
  font-size: 24rpx;
}

.tip-text {
  font-size: 22rpx;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.empty-state {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 4;
  background: #fff;
}

.icon-camera {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.sub-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 操作区 */
.controls-area {
  flex-shrink: 0;
  background: #fff;
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  padding: 20rpx 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
  z-index: 10;
}

.toolbar {
  display: flex;
  justify-content: space-around;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 24rpx;
  color: var(--text-color);
}

.tool-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.tabs {
  display: flex;
  margin-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: var(--sub-text-color);
  position: relative;
}

.tab-item.active {
  color: var(--primary-color);
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 25%;
  width: 50%;
  height: 4rpx;
  background: var(--primary-color);
  border-radius: 4rpx;
}

.options-scroll {
  display: flex;
  white-space: nowrap;
  margin-bottom: 16rpx;
  height: 140rpx;
}

.option-card {
  display: inline-flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  width: 160rpx;
  height: 120rpx;
  background: #f9f9f9;
  margin-right: 20rpx;
  border-radius: var(--radius-md);
  border: 2rpx solid transparent;
  flex-shrink: 0;
}

.option-card.active {
  background: rgba(22, 119, 255, 0.05);
  border-color: var(--primary-color);
  color: var(--primary-color);
}

.opt-name { font-size: 28rpx; font-weight: 500; margin-bottom: 8rpx; }
.opt-desc { font-size: 22rpx; color: #999; }
.opt-px { font-size: 20rpx; color: #ccc; margin-top: 4rpx; }

.option-card.active .opt-desc, .option-card.active .opt-px {
  color: var(--primary-color);
  opacity: 0.8;
}

.color-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 30rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
  border: 4rpx solid #fff;
  flex-shrink: 0;
  position: relative;
  margin-top: 10rpx;
}

.color-circle.active {
  transform: scale(1.1);
  box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.15);
}

.check-mark {
  color: #fff;
  font-size: 32rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

.btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: var(--radius-md);
  font-size: 30rpx;
  border: none;
  padding: 0;
  text-align: center;
}

.btn-group {
  display: flex;
  gap: 20rpx;
}

.btn-group .btn.secondary {
  flex: 1;
}

.btn-group .btn.primary {
  flex: 2;
  background: var(--primary-color);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.3);
}

.btn.secondary {
  background: #f5f5f5;
  color: #666;
}

/* 使用次数提示 */
.usage-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  font-size: 24rpx;
}
.usage-text {
  color: var(--sub-text-color);
}
.usage-redeem {
  color: var(--primary-color);
  text-decoration: underline;
}

/* 兑换码弹窗 */
.redeem-panel {
  padding: 30rpx;
  background: #fff;
  min-height: 300rpx;
}
.redeem-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}
.redeem-desc {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  margin-bottom: 30rpx;
  line-height: 1.6;
}
.redeem-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: 32rpx;
  text-align: center;
  letter-spacing: 8rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}
.redeem-input:focus {
  border-color: var(--primary-color);
}
.redeem-btn {
  width: 100%;
  margin-top: 10rpx;
}
.redeem-error {
  color: #ff4d4f;
  font-size: 24rpx;
  margin-top: 16rpx;
}
.close-btn {
  padding: 10rpx;
  font-size: 32rpx;
  color: #999;
}

.history-btn {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  background: rgba(255,255,255,0.9);
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
  z-index: 100;
  color: var(--text-color);
}

.layout-btn {
  width: 100%;
  margin-top: 16rpx;
  background: #fff;
  color: var(--text-color);
  border: 2rpx solid var(--border-color);
}

/* Layout Panel */
.layout-panel {
  padding: 30rpx;
  background: #fff;
}

.layout-body {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.layout-preview-wrap {
  width: 260rpx;
  height: 360rpx;
  background: #f5f5f5;
  border-radius: var(--radius-md);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.layout-preview {
  width: 100%;
  height: 100%;
}

.layout-preview-empty {
  font-size: 24rpx;
  color: #999;
}

.layout-info {
  margin-bottom: 24rpx;
}

.layout-desc {
  font-size: 26rpx;
  color: var(--sub-text-color);
}

.layout-controls {
  display: flex;
  gap: 40rpx;
  margin-bottom: 30rpx;
}

.layout-ctrl-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.ctrl-label {
  font-size: 26rpx;
  color: var(--sub-text-color);
}

.ctrl-group {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.ctrl-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--primary-color);
  color: #fff;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.ctrl-btn:active {
  opacity: 0.7;
}

.ctrl-val {
  font-size: 36rpx;
  font-weight: 600;
  min-width: 60rpx;
  text-align: center;
}

.layout-body .btn.primary {
  width: 100%;
}

/* History Panel */
.history-panel {
  padding: 30rpx;
  max-height: 60vh;
  min-height: 400rpx;
  background: #fff;
}
