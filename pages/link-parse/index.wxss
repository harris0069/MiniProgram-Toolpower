/* ===== 页面 ===== */
.page {
  padding: 24rpx 30rpx 60rpx;
  min-height: 100vh;
  background: #F5F5F5;
  box-sizing: border-box;
}

/* ===== 输入卡片 ===== */
.input-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.url-input {
  width: 100%;
  min-height: 100rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  background: #F8F8F8;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  line-height: 1.6;
}

.input-placeholder {
  color: #BFBFBF;
  font-size: 28rpx;
}

.input-actions {
  display: flex;
  justify-content: flex-end;
  gap: 32rpx;
  margin-top: 16rpx;
  margin-bottom: 24rpx;
}

.link-btn {
  font-size: 26rpx;
  color: #1677FF;
}

.link-btn:active {
  opacity: 0.6;
}

/* ===== 提交按钮 ===== */
.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 88rpx;
  border-radius: 12rpx;
  background: #1677FF;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.submit-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.submit-btn.disabled {
  opacity: 0.4;
  pointer-events: none;
}

.loading-dot {
  display: inline-block;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #FFFFFF;
  animation: pulse 0.8s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.2); }
}

/* ===== 错误提示 ===== */
.error-toast {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #FFF0F0;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  color: #E74C3C;
}

.error-close {
  font-size: 36rpx;
  color: #E74C3C;
  line-height: 1;
  padding: 0 8rpx;
}

/* ===== 空状态 ===== */
.empty-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0 60rpx;
  gap: 20rpx;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 26rpx;
  color: #BFBFBF;
}

/* ===== 骨架屏 ===== */
.loading-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.skeleton {
  border-radius: 12rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.cover-skeleton {
  width: 100%;
  height: 360rpx;
  margin-bottom: 24rpx;
}

.skeleton-line {
  height: 28rpx;
  border-radius: 6rpx;
  margin-bottom: 16rpx;
}

.skeleton-line.w60 { width: 60%; }
.skeleton-line.w40 { width: 40%; }

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ===== 结果卡片 ===== */
.result-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 封面图 */
.cover-image {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  background: #F0F0F0;
  object-fit: cover;
  margin-bottom: 24rpx;
}

.cover-fallback {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  background: #F8F8F8;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.fallback-icon {
  font-size: 64rpx;
  opacity: 0.3;
}

.fallback-text {
  font-size: 24rpx;
  color: #BFBFBF;
}

/* 视频信息 */
.video-info {
  margin-bottom: 24rpx;
}

.video-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.5;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.video-author {
  display: block;
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
}

/* 清晰度选择 */
.quality-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.quality-tag {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  background: #F5F5F5;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.quality-tag:active {
  opacity: 0.7;
}

.quality-tag.active {
  color: #1677FF;
  background: rgba(22, 119, 255, 0.08);
  border-color: #1677FF;
  font-weight: 600;
}

.quality-tag.unavailable {
  opacity: 0.3;
  text-decoration: line-through;
  pointer-events: none;
  background: #F5F5F5;
}

/* 下载按钮 */
.download-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 12rpx;
  background: #1677FF;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.download-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.download-btn.disabled {
  opacity: 0.4;
  pointer-events: none;
}

/* ===== 底部声明 ===== */
.disclaimer {
  padding: 24rpx 0;
  text-align: center;
}

.disclaimer text {
  font-size: 22rpx;
  color: #BFBFBF;
  line-height: 1.5;
}

/* ===== 使用次数 ===== */
.usage-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #FFFBE6;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  font-size: 26rpx;
  color: #666;
}

.usage-redeem {
  color: #1677FF;
  font-weight: 600;
}

.usage-redeem:active {
  opacity: 0.6;
}

/* ===== 兑换弹窗 ===== */
.redeem-panel {
  padding: 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
}

.close-btn {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 36rpx;
  color: #999;
  border-radius: 50%;
  background: #F5F5F5;
}

.close-btn:active {
  background: #E8E8E8;
}

.redeem-body {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.redeem-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
}

.redeem-input {
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  background: #F8F8F8;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.redeem-input:focus {
  background: #FFF;
  border: 2rpx solid #1677FF;
}

.redeem-btn {
  margin-top: 8rpx;
}

.redeem-error {
  font-size: 24rpx;
  color: #E74C3C;
  text-align: center;
}
