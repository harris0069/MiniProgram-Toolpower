page {
  background-color: var(--bg-color);
  height: 100vh;
  display: flex;
  flex-direction: column;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Heiti SC", sans-serif;
}

.container {
  flex: 1;
  padding: 25rpx;
  box-sizing: border-box;
}

.guide-tip {
  text-align: center;
  font-size: 12px;
  color: var(--text-sub);
  margin-bottom: 20rpx;
}

/* 历史入口 */
.card-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.history-entry, .limit-entry {
  display: flex;
  flex-direction: row;
  align-items: center;
  font-size: 13px;
  color: var(--secondary-color);
  background: rgba(212, 185, 140, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  transition: all 0.2s;
}

.history-entry:active, .limit-entry:active {
  background: rgba(212, 185, 140, 0.2);
  transform: scale(0.98);
}

.history-icon, .limit-entry .icon {
  margin-right: 6rpx;
  font-size: 14px;
}

.limit-entry {
  color: #E65100;
  background: #FFF3E0;
}

.limit-entry:active {
  background: #FFE0B2;
}

/* 输入卡片 */
.input-card {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  padding: 30rpx;
  margin-bottom: 25rpx;
  box-shadow: var(--shadow-sm);
}

.input-group {
  margin-bottom: 30rpx;
}

.input-label {
  font-size: 14px;
  color: var(--text-main);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.unit-text {
  font-size: 12px;
  color: var(--text-sub);
  font-weight: normal;
}

.input-wrapper {
  background: #fff;
  border-radius: 14rpx;
  padding: 0 20rpx;
  height: 88rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  border: 2rpx solid #eee;
  transition: all 0.3s;
}

.input-wrapper.focus {
  border-color: var(--secondary-color);
  box-shadow: 0 0 10rpx rgba(212, 185, 140, 0.2);
}

.input-field {
  flex: 1;
  height: 100%;
  font-size: 20px;
  font-weight: bold;
  color: var(--text-main);
}

.slider-bar {
  margin-top: 10rpx;
}

/* 按钮组 */
.btn-group {
  display: flex;
  justify-content: space-between;
  gap: 30rpx;
  margin-top: 50rpx;
}

.btn {
  border-radius: var(--radius-md);
  font-size: 16px;
  font-weight: 600;
  height: 96rpx;
  line-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  border: none;
}

.btn::after {
  border: none;
}

.btn:active {
  transform: scale(0.98);
}

.reset {
  width: 200rpx;
  background-color: #f5f5f5;
  color: #666;
}

.submit {
  flex: 1;
  background: linear-gradient(135deg, var(--secondary-color), #C8A562);
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(212, 185, 140, 0.4);
}

.submit[disabled] {
  background: #e0e0e0;
  color: #aaa;
  box-shadow: none;
}

/* 结果展示区容器 */
.result-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  animation: fadeIn 0.5s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 结果卡片 */
.result-card {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  padding: 40rpx;
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.bmi-main {
  display: flex;
  flex-direction: column;
}

.bmi-val {
  font-size: 56px;
  font-weight: bold;
  color: var(--text-main);
  line-height: 1;
  font-family: 'DIN Alternate', sans-serif;
}

.bmi-label {
  font-size: 12px;
  color: var(--text-sub);
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}

.status-badge {
  padding: 10rpx 30rpx;
  border-radius: 40rpx;
  font-size: 14px;
  font-weight: 600;
  margin-top: 10rpx;
}

.divider {
  height: 2rpx;
  background: #f0f0f0;
  margin: 10rpx 0 30rpx;
}

/* 信息网格 */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30rpx;
  margin-bottom: 40rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  background: #f9f9f9;
  padding: 20rpx;
  border-radius: 12rpx;
}

.info-item .label {
  font-size: 12px;
  color: #999;
  margin-bottom: 8rpx;
}

.info-item .value {
  font-size: 14px;
  color: var(--text-main);
  font-weight: 600;
  line-height: 1.4;
}

.info-item .value.highlight {
  color: #F57C00;
  font-size: 13px;
  white-space: pre-wrap;
}

/* 健康建议 */
.health-advice {
  background: rgba(212, 185, 140, 0.1);
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 40rpx;
}

.advice-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--secondary-color);
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.advice-title .icon {
  margin-right: 10rpx;
}

.advice-content {
  font-size: 13px;
  color: var(--text-main);
  line-height: 1.6;
  text-align: justify;
}

/* 操作按钮行 */
.action-row {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  font-size: 14px;
  font-weight: 500;
  transition: all 0.2s;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.action-btn::after { border: none; }
.action-btn:active { transform: scale(0.98); }

.action-btn.secondary {
  background: #f5f5f5;
  color: #666;
}

.action-btn.primary {
  background: #fff;
  color: var(--secondary-color);
  border: 2rpx solid var(--secondary-color);
}

/* 目标设置卡片 */
.target-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 30rpx;
  box-shadow: var(--shadow-sm);
}

.card-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 24rpx;
}

.target-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.target-input-row {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
}

.target-input-row .label {
  font-size: 13px;
  color: #666;
  margin-right: 16rpx;
}

.target-input {
  width: 100rpx;
  font-size: 16px;
  font-weight: bold;
  color: var(--text-main);
}

.target-tip {
  font-size: 12px;
  color: #999;
}

/* 底部占位 */
.footer-spacer {
  height: 120rpx;
  width: 100%;
}

/* 状态颜色 */
.status-thin { background: #E3F2FD; color: #1976D2; }
.status-normal { background: #E8F5E9; color: #388E3C; }
.status-overweight { background: #FFF3E0; color: #F57C00; }
.status-obese { background: #FFEBEE; color: #D32F2F; }


/* 底部功能链接 */
.page-footer-links {
  display: flex;
  justify-content: center;
  padding: 20rpx 0;
  margin-top: 20rpx;
}

.link-item {
  display: flex;
  align-items: center;
  font-size: 13px;
  color: var(--text-sub);
  background: #fff;
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  box-shadow: var(--shadow-sm);
}

.link-item .icon {
  margin-right: 10rpx;
}

/* 底部固定警告按钮 */
/* 已移除固定按钮，样式合并至 card-header .limit-entry */

/* 自定义模态框 */
.custom-modal {
  visibility: hidden;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2000;
  pointer-events: none;
}

.custom-modal.active {
  visibility: visible;
  pointer-events: auto;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  opacity: 0;
  transition: opacity 0.3s;
}

.custom-modal.active .modal-mask {
  opacity: 1;
}

/* 局限性面板 */
.limit-panel {
  background-color: #fff;
  border-top-left-radius: 30rpx;
  border-top-right-radius: 30rpx;
  padding: 30rpx;
  height: 80vh;
  display: flex;
  flex-direction: column;
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.custom-modal.active .limit-panel {
  transform: translateY(0);
}

.limit-scroll {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 40rpx;
}

.close-icon {
  font-size: 24px;
  color: #999;
  padding: 10rpx;
  line-height: 1;
}

.limit-intro {
  font-size: 14px;
  color: var(--text-main);
  line-height: 1.6;
  background: #f9f9f9;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.limit-intro .highlight {
  color: #D32F2F;
  font-weight: 600;
  display: block;
  margin-top: 10rpx;
}

.limit-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.limit-item {
  border-bottom: 1rpx dashed #eee;
  padding-bottom: 24rpx;
}

.limit-item:last-child {
  border-bottom: none;
}

.li-head {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.li-dot {
  width: 36rpx;
  height: 36rpx;
  background: var(--secondary-color);
  color: #fff;
  border-radius: 50%;
  font-size: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.li-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-main);
}

.li-desc {
  font-size: 13px;
  color: #666;
  line-height: 1.6;
  padding-left: 52rpx;
}

.li-desc text {
  display: block;
  margin-bottom: 8rpx;
}

/* 核心提醒 */
.core-warning {
  margin-top: 40rpx;
  background: #FFF3E0;
  border: 2rpx solid #FFCC80;
  border-radius: 16rpx;
  padding: 30rpx;
}

.warn-title {
  font-size: 15px;
  font-weight: bold;
  color: #E65100;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.warn-desc {
  font-size: 13px;
  color: #E65100;
  line-height: 1.6;
}

.warn-points {
  font-weight: bold;
  font-size: 14px;
  margin: 10rpx 0;
  text-align: center;
  background: rgba(255,255,255,0.5);
  padding: 10rpx;
  border-radius: 8rpx;
}

/* 历史记录面板 */
.history-panel {
  background-color: #fff;
  border-top-left-radius: 30rpx;
  border-top-right-radius: 30rpx;
  padding: 30rpx;
  height: 60vh;
  display: flex;
  flex-direction: column;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  font-size: 16px;
  font-weight: 600;
  color: var(--text-main);
}

.panel-header .clear-btn {
  font-size: 13px;
  color: var(--text-sub);
  padding: 10rpx 20rpx;
}

.history-list {
  flex: 1;
  overflow-y: auto;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.h-left {
  display: flex;
  align-items: center;
  width: 140rpx;
}

.h-bmi {
  font-size: 20px;
  font-weight: bold;
  color: var(--text-main);
  margin-right: 16rpx;
  font-family: 'DIN Alternate', sans-serif;
}

.h-status {
  font-size: 11px;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.h-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin-left: 20rpx;
}

.h-date {
  font-size: 12px;
  color: var(--text-sub);
  margin-bottom: 4rpx;
}

.h-detail {
  font-size: 13px;
  color: var(--text-main);
}

.h-delete {
  padding: 10rpx;
  color: #999;
  font-size: 18px;
  margin-left: 20rpx;
}

.empty-tip {
  text-align: center;
  color: #999;
  margin-top: 100rpx;
  font-size: 14px;
}
