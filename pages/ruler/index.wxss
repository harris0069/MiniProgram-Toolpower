page {
  background-color: #f5f5f5;
  height: 100vh;
  overflow: hidden;
}

.container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
}

/* Canvas 尺子 */
.ruler-canvas {
  flex: 1;
  width: 100%;
  height: 100%;
}

/* 控制按钮 */
.controls {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  padding: 20rpx;
  border-radius: 60rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  z-index: 100;
  transition: all 0.3s ease;
}

.controls.locked {
  opacity: 0.6;
}

.control-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 100rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 2rpx solid #e0e0e0;
  transition: all 0.2s ease;
}

.control-btn.active {
  background: var(--primary-color);
  border-color: var(--primary-color);
}

.control-btn.active .btn-icon,
.control-btn.active .btn-text {
  color: #fff;
}

.btn-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.btn-text {
  font-size: 22rpx;
  color: #666;
}

/* 使用提示 */
.tips {
  position: fixed;
  bottom: 200rpx;
  left: 50%;
  transform: translateX(-50%);
  max-width: 600rpx;
  background: rgba(255, 255, 255, 0.95);
  padding: 20rpx 30rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  gap: 15rpx;
  z-index: 50;
  animation: fadeIn 0.3s ease;
}

.tip-icon {
  font-size: 32rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 彩蛋 */
.easter-egg {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0);
  z-index: 1000;
  opacity: 0;
  transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

.easter-egg.show {
  transform: translate(-50%, -50%) scale(1);
  opacity: 1;
}

.easter-egg-content {
  background: rgba(0, 0, 0, 0.85);
  color: #fff;
  padding: 40rpx 60rpx;
  border-radius: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.3);
}

.easter-egg-emoji {
  font-size: 80rpx;
  animation: bounce 0.6s ease infinite;
}

.easter-egg-text {
  font-size: 28rpx;
  text-align: center;
  line-height: 1.6;
  max-width: 500rpx;
}

/* 动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateX(-50%) translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}
