<navigation-bar
  title="{{mode === 'category' ? '一键海报' : mode === 'entry' ? currentEntry.entryName : selectedTemplate.name}}"
  statusBarHeight="{{statusBarHeight}}"
  navBarHeight="{{navBarHeight}}"
  delta="{{0}}"
  bind:back="onBack"
></navigation-bar>

<!-- 分类页 -->
<view wx:if="{{mode === 'category'}}" class="page">
  <view class="category-tabs">
    <view class="cat-tab {{categoryTab === '全部' ? 'active' : ''}}" bindtap="onCategoryTab" data-cat="全部">全部</view>
    <view class="cat-tab {{categoryTab === '节假日' ? 'active' : ''}}" bindtap="onCategoryTab" data-cat="节假日">节假日</view>
    <view class="cat-tab {{categoryTab === '节气' ? 'active' : ''}}" bindtap="onCategoryTab" data-cat="节气">24节气</view>
  </view>

  <scroll-view class="entry-grid" scroll-y>
      <view class="entry-card" wx:for="{{filteredEntries}}" wx:key="entry" bindtap="enterEntry" data-entry="{{item.entry}}">
      <view class="entry-thumb">
        <text class="entry-emoji">{{item._icon}}</text>
      </view>
      <text class="entry-name">{{item.entryName}}</text>
      <text class="entry-count">{{item.templates.length}}个模板</text>
    </view>
    <view class="empty-hint" wx:if="{{filteredEntries.length === 0}}">
      <text>暂无数据</text>
    </view>
  </scroll-view>
</view>

<!-- 模板列表页 -->
<view wx:elif="{{mode === 'entry'}}" class="page">
  <scroll-view class="template-grid" scroll-y>
    <view class="template-grid-inner">
      <view class="tpl-card" wx:for="{{templates}}" wx:key="id" bindtap="selectTemplate" data-id="{{item.id}}">
        <view class="tpl-thumb-wrap">
          <image class="tpl-thumb" src="{{IMG_BASE + item.thumbnail}}" mode="aspectFill" wx:if="{{item.thumbnail}}" />
          <text class="tpl-emoji" wx:else>🖼️</text>
          <view wx:if="{{item.tier === 'premium'}}" class="tpl-lock">
            <text>🔒</text>
            <text class="lock-text">待解锁</text>
          </view>
        </view>
        <text class="tpl-name">{{item.name}}</text>
        <text class="tpl-tier {{item.tier}}">{{item.tier === 'free' ? '免费' : '高级'}}</text>
      </view>
    </view>
  </scroll-view>
</view>

<!-- 编辑页 -->
<view wx:elif="{{mode === 'edit'}}" class="page edit-page" style="height:{{editPageHeight}}px" hidden="{{fullscreenOpen}}">
  <!-- 画布区域 -->
  <view class="preview-section">
    <canvas wx:if="{{hasImage}}" type="2d" id="posterCanvas" class="poster-canvas"
      style="width:{{canvasW}}px;height:{{canvasH}}px"
      bindtouchstart="onTouchStart" catchtouchmove="onTouchMove" bindtouchend="onTouchEnd"
    ></canvas>
    <view wx:else class="loading-placeholder">
      <text class="loading-text">加载中...</text>
    </view>
    <view class="fullscreen-btn" catchtap="openFullscreen">⛶ 全屏</view>
  </view>

  <!-- 底部：工具栏 + 上下文面板 -->
  <view class="editor-bottom">
    <view class="editor-slide {{toolbarExpanded ? 'expanded' : ''}}">
      <view class="toolbar">
        <view class="toolbar-btn {{activeTool === 'logo' ? 'active' : ''}}" bindtap="switchTool" data-tool="logo">
          <text class="tb-label">Logo</text>
        </view>
        <view class="toolbar-btn {{activeTool === 'text' ? 'active' : ''}}" bindtap="switchTool" data-tool="text">
          <text class="tb-label">文字</text>
        </view>
        <view class="toolbar-btn save-btn {{!used && !previewMode && !saving ? '' : 'disabled'}}" bindtap="saveToAlbum">
          <text class="tb-label">{{saving ? '保存中' : '保存'}}</text>
        </view>
      </view>

      <scroll-view class="context-panel" scroll-y wx:if="{{activeTool === 'logo'}}">
        <view class="param-group">
          <button class="upload-btn" bindtap="chooseLogo">{{logoPath ? '更换Logo' : '选择Logo'}}</button>
        </view>
        <view class="param-group" wx:if="{{logoPath}}">
          <view class="param-label">缩放 {{logoScalePercent}}%</view>
          <slider min="10" max="300" value="{{logoScalePercent}}" bindchange="onLogoScale" block-size="24" activeColor="#4A90D9" />
        </view>
      </scroll-view>

      <scroll-view class="context-panel" scroll-y wx:elif="{{activeTool === 'text'}}">
        <view class="param-group">
          <button class="upload-btn" bindtap="addText">+ 添加文字</button>
        </view>
        <view class="text-chip-row" wx:if="{{texts.length > 0}}">
          <scroll-view class="text-chip-scroll" scroll-x>
            <view wx:for="{{texts}}" wx:key="key" class="text-chip {{currentTextKey === item.key ? 'active' : ''}}" bindtap="onTextSelect" data-key="{{item.key}}">
              <text class="chip-text">{{item.content || '空'}}</text>
              <view class="chip-color" style="background:{{item.color}}"></view>
            </view>
          </scroll-view>
        </view>
        <view class="param-group" wx:if="{{currentText}}">
          <view class="param-label">文字内容</view>
          <input class="param-input" placeholder="请输入文字" value="{{currentText.content}}" data-key="{{currentText.key}}" bindinput="onTextInput" />
        </view>
        <view class="param-group" wx:if="{{currentText}}">
          <view class="param-label">字号 {{currentText.fontSize}}</view>
          <slider min="5" max="200" value="{{currentText.fontSize}}" data-key="{{currentText.key}}" bindchange="onTextFontSize" block-size="24" activeColor="#4A90D9" />
        </view>
        <view class="param-group" wx:if="{{currentText}}">
          <view class="param-label">颜色</view>
          <view class="color-picker">
            <view class="color-item {{currentText.color === '#ffffff' ? 'active' : ''}}" style="background:#ffffff;border:1rpx solid #ddd" bindtap="onTextColor" data-key="{{currentText.key}}" data-color="#ffffff"></view>
            <view class="color-item {{currentText.color === '#000000' ? 'active' : ''}}" style="background:#000000" bindtap="onTextColor" data-key="{{currentText.key}}" data-color="#000000"></view>
            <view class="color-item {{currentText.color === '#FF6B6B' ? 'active' : ''}}" style="background:#FF6B6B" bindtap="onTextColor" data-key="{{currentText.key}}" data-color="#FF6B6B"></view>
            <view class="color-item {{currentText.color === '#FFD93D' ? 'active' : ''}}" style="background:#FFD93D" bindtap="onTextColor" data-key="{{currentText.key}}" data-color="#FFD93D"></view>
            <view class="color-item {{currentText.color === '#4ECDC4' ? 'active' : ''}}" style="background:#4ECDC4" bindtap="onTextColor" data-key="{{currentText.key}}" data-color="#4ECDC4"></view>
            <view class="color-item {{currentText.color === '#6C5CE7' ? 'active' : ''}}" style="background:#6C5CE7" bindtap="onTextColor" data-key="{{currentText.key}}" data-color="#6C5CE7"></view>
            <view class="color-item picker-btn {{pickingColor ? 'active' : ''}}" bindtap="startColorPicker">🎨</view>
          </view>
        </view>
        <view class="param-group" wx:if="{{currentText}}">
          <view class="cp-del-btn" bindtap="deleteText">删除此文字</view>
        </view>
      </scroll-view>

      <view class="context-panel context-hint" wx:if="{{!activeTool}}">
        <text class="hint-text">点击画布文字或Logo进行编辑</text>
      </view>
    </view>

    <view class="toolbar-toggle" catchtap="toggleToolbar">
      <view class="toggle-left">
        <text class="toggle-arrow">{{toolbarExpanded ? '▼' : '▲'}}</text>
        <text>{{toolbarExpanded ? '收起' : '展开编辑'}}</text>
      </view>
      <view class="toggle-save {{!used && !previewMode && !saving ? '' : 'disabled'}}" catchtap="saveToAlbum">
        <text>💾</text>
      </view>
    </view>
  </view>
</view>

<!-- 全屏预览遮罩 -->
<view wx:if="{{fullscreenOpen && fullscreenSrc}}" class="fullscreen-overlay" bindtap="closeFullscreen">
  <image class="fullscreen-image" src="{{fullscreenSrc}}" mode="aspectFit" />
</view>

<!-- 解锁弹窗 -->
<page-container show="{{unlockModal}}" round position="bottom" bindclickoverlay="closeUnlock">
  <view class="unlock-panel">
    <view class="panel-header">
      <text>模板待解锁</text>
      <view class="close-btn" bindtap="closeUnlock">✕</view>
    </view>
    <view class="panel-body">
      <text class="unlock-desc">{{unlockMsg}}</text>
      <button class="btn preview-btn" bindtap="previewTemplate">预览模板</button>
      <button class="btn close-btn2" bindtap="closeUnlock">知道了</button>
    </view>
  </view>
</page-container>
