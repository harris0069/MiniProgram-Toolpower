/* ===== 页面基础 ===== */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ===== 场景列表模式 ===== */
.list-mode {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.list-header {
  padding: 40rpx 30rpx 20rpx;
}
.list-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.scene-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding: 0 30rpx;
}

.scene-card {
  position: relative;
  overflow: hidden;
  background: #fff;
  border-radius: var(--radius-xxl, 24rpx);
  padding: 40rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-md, 0 4rpx 16rpx rgba(0,0,0,0.06));
  animation: cardFadeIn 0.4s ease both;
}
.scene-card:active {
  transform: scale(0.96);
}

.scene-card-bar {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 8rpx;
}

@keyframes cardFadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.scene-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.scene-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.scene-desc {
  font-size: 22rpx;
  color: #999;
  text-align: center;
}

/* ===== 转盘页面（flex 百分比布局） ===== */
.wheel-page {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ---- 结果区：白底圆角卡片，固定2行文字高度 ---- */
.result-card {
  flex-shrink: 0;
  width: 85%;
  margin: 12rpx auto 4rpx;
  background: #fff;
  border-radius: var(--radius-xxl, 24rpx);
  box-shadow: var(--shadow-md, 0 4rpx 16rpx rgba(0,0,0,0.06));
  transition: background 0.5s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  padding: 12rpx 20rpx;
}

.result-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a2e;
  text-align: center;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  animation: fadeIn 0.3s ease;
}

.result-text.result-show {
  color: #fff;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(4rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ---- 转盘核心区：按内容高度撑开，仅含转盘 ---- */
.wheel-core {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ---- 转盘容器：宽 85% 屏幕，正方形，圆心居中 ---- */
.wheel-box {
  position: relative;
  width: 85%;
  aspect-ratio: 1 / 1;
  flex-shrink: 0;
}

/* ---- 转盘画布：填满容器，正圆 ---- */
.wheel-canvas {
  display: block;
  width: 100%;
  height: 100%;
  flex-shrink: 0;
  border-radius: 50%;
  box-shadow: var(--shadow-lg, 0 8rpx 32rpx rgba(0,0,0,0.12)), inset 0 0 0 6rpx rgba(255,255,255,0.5);
}

/* ---- 操作按钮区 ---- */
.action-bar {
  flex-shrink: 0;
  display: flex;
  justify-content: center;
  width: 100%;
  margin-top: 16rpx;
}

.start-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 70%;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  box-shadow: 0 8rpx 24rpx rgba(255,107,107,0.35);
  transition: all 0.2s;
}
.start-btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}
.start-btn.disabled {
  background: linear-gradient(135deg, #bbb, #ddd);
  box-shadow: none;
  pointer-events: none;
}
.start-btn.again {
  background: linear-gradient(135deg, #4ECDC4, #45B7D1);
  box-shadow: 0 8rpx 24rpx rgba(78,205,196,0.35);
}

.start-btn-text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

/* ---- 选项列表区：flex:1 填充剩余空间，可折叠滚动 ---- */
.options-panel {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  padding: 24rpx 30rpx 12rpx;
}

.options-header {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 12rpx;
}
.options-header:active {
  opacity: 0.6;
}
.options-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a2e;
}
.options-toggle {
  font-size: 22rpx;
  color: #999;
}

.options-scroll {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.options-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 6rpx;
  padding-bottom: 8rpx;
}

.option-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  background: rgba(255,255,255,0.6);
}

.option-index {
  flex-shrink: 0;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
}

.option-name {
  font-size: 24rpx;
  color: #333;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ---- 选项列表：中奖项高亮 ---- */
.option-item-winner {
  background: rgba(255, 215, 0, 0.12);
  border: 2rpx solid rgba(255, 215, 0, 0.5);
  box-shadow: 0 0 20rpx rgba(255, 215, 0, 0.15);
}
.option-item-winner .option-name {
  color: #B8860B;
  font-weight: 700;
}
