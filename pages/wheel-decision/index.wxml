<navigation-bar 
  title="{{mode === 'list' ? '转盘决策' : currentScene.name}}" 
  back="{{true}}"
  delta="{{0}}"
  homeButton="{{false}}"
  bind:back="onBack"
></navigation-bar>

<!-- 场景列表 -->
<view wx:if="{{mode === 'list'}}" class="list-mode">
  <view class="list-header">
    <text class="list-title">选择场景</text>
  </view>
  <view class="scene-grid">
    <view 
      class="scene-card" 
      wx:for="{{displayScenes}}" 
      wx:key="id"
      bindtap="enterScene" 
      data-id="{{item.id}}"
      style="animation-delay: {{index * 80}}ms;"
    >
      <view class="scene-card-bar" style="background: {{item.ui.bgGradient[0]}};"></view>
      <view class="scene-icon">{{item.icon}}</view>
      <text class="scene-name">{{item.name}}</text>
      <text class="scene-desc">{{item.desc}}</text>
    </view>
  </view>
</view>

<!-- 转盘模式 -->
<view wx:if="{{mode === 'wheel'}}" class="wheel-page" style="background: {{bgGradient}};">
  <!-- 结果区：白底圆角卡片，固定2行文字高度 -->
  <view class="result-card" style="background: {{showResult ? pointerColor : '#fff'}};">
    <text class="result-text {{showResult ? 'result-show' : ''}}">{{resultDisplay}}</text>
  </view>

  <!-- 转盘区域：仅转盘，按内容高度撑开 -->
  <view class="wheel-core">
    <view class="wheel-box" bindtap="startSpin">
      <canvas type="2d" id="wheelCanvas" class="wheel-canvas"></canvas>
    </view>
  </view>

  <!-- 操作按钮区 -->
  <view class="action-bar">
    <view class="start-btn {{isSpinning ? 'disabled' : ''}}" bindtap="startSpin" wx:if="{{!showResult}}">
      <text class="start-btn-text">{{isSpinning ? '转动中...' : '开始转动'}}</text>
    </view>
    <view class="start-btn again" bindtap="startSpin" wx:if="{{showResult}}">
      <text class="start-btn-text">再来一次</text>
    </view>
  </view>

  <!-- 选项列表区：flex:1.5 约占 35%，可折叠滚动 -->
  <view class="options-panel">
    <view class="options-header" bindtap="toggleOptions">
      <text class="options-title">全部选项（{{currentOptions.length}}项）</text>
      <text class="options-toggle">{{optionsExpanded ? '收起 ▲' : '展开 ▼'}}</text>
    </view>
    <scroll-view wx:if="{{optionsExpanded}}" class="options-scroll" scroll-y
                  scroll-into-view="{{winningIndex >= 0 ? 'opt-' + winningIndex : ''}}">
      <view class="options-grid">
        <view 
          class="option-item {{winningIndex === index ? 'option-item-winner' : ''}}"
          id="opt-{{index}}"
          wx:for="{{currentOptions}}" 
          wx:key="index"
        >
          <text class="option-index" style="background: {{currentColors[index % currentColors.length]}}">{{index + 1}}</text>
          <text class="option-name">{{item}}</text>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
