<navigation-bar
  title="{{mode === 'select' ? '拂去虚纹' : mode === 'edit' ? '涂抹水印区域' : '处理结果'}}"
  statusBarHeight="{{statusBarHeight}}"
  navBarHeight="{{navBarHeight}}"
  delta="{{0}}"
  bind:back="onBack"
></navigation-bar>

<!-- 选图 -->
<view wx:if="{{mode === 'select'}}" class="page select-page">
  <view class="select-area">
    <view class="select-icon">🖌️</view>
    <text class="select-title">拂去虚纹</text>
    <text class="select-desc">涂抹水印区域，一键去除</text>
    <button class="select-btn" bindtap="chooseImage">从相册选择图片</button>
  </view>
</view>

<!-- 涂抹编辑 -->
<view wx:elif="{{mode === 'edit'}}" class="page edit-page">
  <view class="canvas-wrap">
    <canvas type="2d" id="paintCanvas"
      class="paint-canvas"
      bindtouchstart="onTouchStart"
      bindtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
    ></canvas>
  </view>

  <view class="toolbar">
    <view class="tool-row">
      <view class="tool-btn" bindtap="undoLast">
        <text>↩ 撤销</text>
      </view>
      <view class="tool-btn" bindtap="clearMask">
        <text>🗑️ 清除</text>
      </view>
    </view>
    <view class="tool-row">
      <text class="size-label">笔刷: {{brushSize}}px</text>
      <slider min="5" max="50" value="{{brushSize}}" bindchange="onBrushSize" block-size="24" class="size-slider" />
    </view>
    <view class="tool-row">
      <view class="process-btn {{processing ? 'disabled' : ''}}" bindtap="processImage">
        <text>{{processing ? '处理中...' : '✨ 去水印'}}</text>
      </view>
    </view>
  </view>
</view>

<!-- 结果 -->
<view wx:elif="{{mode === 'result'}}" class="page result-page">
  <scroll-view scroll-y class="result-scroll">
    <image class="result-image" src="{{resultPath}}" mode="widthFix"></image>
  </scroll-view>
  <view class="result-bar">
    <view class="result-btn save-btn" bindtap="saveToAlbum">💾 保存到相册</view>
    <view class="result-btn back-btn" bindtap="startOver">🔄 重新开始</view>
  </view>
</view>
