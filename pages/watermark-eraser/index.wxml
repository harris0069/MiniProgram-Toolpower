<navigation-bar
  title="{{mode === 'select' ? '拂去虚纹' : mode === 'edit' ? '涂抹水印区域' : '处理结果'}}"
  statusBarHeight="{{statusBarHeight}}"
  navBarHeight="{{navBarHeight}}"
  delta="{{0}}"
  bind:back="onBack"
></navigation-bar>

<!-- 选图 -->
<view wx:if="{{mode === 'select'}}" class="page select-page">
  <view class="select-area">
    <view class="select-icon">🖌️</view>
    <text class="select-title">拂去虚纹</text>
    <text class="select-desc">涂抹水印区域，一键去除</text>
    <button class="select-btn" bindtap="chooseImage">从相册选择图片</button>
  </view>
</view>

<!-- 涂抹编辑 + 结果 — 共享布局 -->
<view wx:elif="{{mode === 'edit' || mode === 'result'}}" class="page edit-page">
  <view class="canvas-wrap">
    <canvas type="2d" id="paintCanvas"
      class="paint-canvas"
      bindtouchstart="onTouchStart"
      catchtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
    ></canvas>

    <!-- 处理中遮罩 -->
    <view wx:if="{{processing}}" class="processing-overlay">
      <view class="processing-box">
        <view class="processing-spinner"></view>
        <text class="processing-text">{{progressText}}</text>
      </view>
    </view>

    <!-- 长按对比 -->
    <view wx:if="{{mode === 'result' && !processing}}" class="compare-hint">长按对比原图</view>
  </view>

  <view class="toolbar">
    <!-- 编辑工具栏 -->
    <view wx:if="{{mode === 'edit' && !processing}}">
      <view class="tool-row">
        <view class="tool-btn" bindtap="undoLast">
          <text>↩ 撤销</text>
        </view>
        <view class="tool-btn" bindtap="clearMask">
          <text>🗑️ 清除</text>
        </view>
      </view>
      <view class="tool-row">
        <text class="size-label">笔刷: {{brushSize}}px</text>
        <slider min="5" max="50" value="{{brushSize}}" bindchange="onBrushSize" block-size="24" class="size-slider" />
      </view>
      <view class="tool-row">
        <view class="process-btn" bindtap="processImage">
          <text>✨ 去水印</text>
        </view>
      </view>
    </view>

    <!-- 结果工具栏 -->
    <view wx:elif="{{mode === 'result' && !processing}}">
      <view class="tool-row result-row">
        <view class="result-btn save-btn" bindtap="saveToAlbum">💾 保存</view>
        <view class="result-btn redo-btn" bindtap="redoEdit">✏️ 重涂</view>
        <view class="result-btn back-btn" bindtap="startOver">🔄 重选</view>
      </view>
    </view>
  </view>
</view>
