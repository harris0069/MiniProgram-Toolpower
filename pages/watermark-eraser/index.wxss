page { background: var(--bg-color); height: 100vh; }
.page { display: flex; flex-direction: column; height: 100vh; overflow: hidden; }

/* Select */
.select-page { align-items: center; justify-content: center; }
.select-area { display: flex; flex-direction: column; align-items: center; gap: 16rpx; padding: 0 60rpx; }
.select-icon { font-size: 120rpx; }
.select-title { font-size: 40rpx; font-weight: 600; color: var(--text-color); }
.select-desc { font-size: 28rpx; color: var(--sub-text-color); }
.select-btn {
  margin-top: 40rpx; width: 100%; height: 96rpx; background: var(--primary-color); color: #fff;
  border-radius: var(--radius-lg); font-size: 30rpx; display: flex; align-items: center; justify-content: center;
}
.select-btn::after { border: none; }
.select-btn:active { opacity: 0.7; }

/* Edit */
.edit-page { background: #000; }
.canvas-wrap { flex: 1; display: flex; align-items: center; justify-content: center; overflow: hidden; }
.paint-canvas { width: 100%; height: 100%; }

.toolbar {
  flex-shrink: 0; background: #1a1a1a; padding: 16rpx 20rpx calc(16rpx + env(safe-area-inset-bottom));
}
.tool-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.tool-row:last-child { margin-bottom: 0; }
.tool-btn {
  flex: 1; padding: 14rpx 0; text-align: center; font-size: 24rpx; color: #999;
  background: #2a2a2a; border-radius: var(--radius-lg);
}
.tool-btn:active { opacity: 0.7; }
.tool-btn.active { background: var(--primary-color); color: #fff; }
.size-label { font-size: 24rpx; color: #999; width: 120rpx; flex-shrink: 0; }
.size-slider { flex: 1; }
.process-btn {
  flex: 1; height: 80rpx; background: var(--primary-color); color: #fff; border-radius: var(--radius-lg);
  display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 600;
}
.process-btn:active { opacity: 0.7; }
.process-btn.disabled { opacity: 0.5; pointer-events: none; }

/* Result */
.result-page { background: #000; }
.result-scroll { flex: 1; }
.result-image { width: 100%; display: block; }
.result-bar {
  flex-shrink: 0; display: flex; gap: 16rpx;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #1a1a1a;
}
.result-btn {
  flex: 1; height: 88rpx; border-radius: var(--radius-lg); font-size: 28rpx;
  display: flex; align-items: center; justify-content: center;
}
.save-btn { background: var(--primary-color); color: #fff; }
.back-btn { background: #2a2a2a; color: #999; }
